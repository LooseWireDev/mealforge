# mealforge configuration — every variable is optional and has a sane default.
# Docker users: only APP_URL matters (set it in a .env next to docker-compose.yml).

# Public URL of this instance, as your household reaches it. Returned by the
# MCP tools so the model can link you to the app after pushing a plan.
APP_URL=http://localhost:8090

# --- The rest only matter when running the server outside Docker ---

# SQLite database location (the file is created on first run).
DATABASE_URL=file:./data/mealforge.db

# Port the server listens on.
PORT=3000

# Path to the built web app the server should serve (Docker sets this itself).
# WEB_DIST=../web/dist
